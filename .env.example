# --- Database (Postgres) ---
POSTGRES_DB=trustcopilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Use @postgres when API runs in Docker Compose; the API rewrites this to localhost when run on the host.
# For local uvicorn without Docker, you can set localhost explicitly: ...@localhost:5432/...
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/trustcopilot

# --- Session (auth cookie; change in production) ---
SESSION_SECRET=placeholder

# --- Email (optional; without SMTP_HOST invites/password-reset log to API stdout only) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# Dev only: return password-reset link in JSON (forgot-password) so UI works without inbox. Never enable in production.
# TRUST_COPILOT_DEV_RETURN_RESET_URL=1

# --- App URLs (must match where the app is served; OAuth redirect_uri is built from APP_BASE_URL) ---
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
# Trusted frontend origins for CORS and CSRF (login, API). Comma-separated. If unset: dev = FRONTEND_URL + localhost variants; prod = FRONTEND_URL only. Set when frontend runs on a different port (e.g. FRONTEND_URL=http://localhost:3003) or multiple origins.
# TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3003
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public Trust page (/trust) workspace; set to override default 1 (e.g. single-tenant or default workspace)
# NEXT_PUBLIC_TRUST_WORKSPACE_ID=1

# --- S3 / MinIO ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=placeholder
S3_SECRET_KEY=placeholder
S3_BUCKET_RAW=trustcopilot-raw
S3_BUCKET_EXPORTS=trustcopilot-exports
S3_USE_SSL=false

# --- OpenAI (required for embeddings and answer generation) ---
OPENAI_API_KEY=placeholder

# --- Optional: app behavior ---
EXPORT_ANSWER_COL_OFFSET=1
# MAX_UPLOAD_BYTES=52428800

# --- Optional: OAuth (Google, GitHub) and Auth0 SSO (uncomment and set to enable) ---
# For Google: in Cloud Console set Authorized redirect URI to {APP_BASE_URL}/api/auth/oauth/google/callback (e.g. http://localhost:3000/api/auth/oauth/google/callback)
# For GitHub: in OAuth App settings set Authorization callback URL to {APP_BASE_URL}/api/auth/oauth/github/callback
# OAUTH_GOOGLE_CLIENT_ID=placeholder
# OAUTH_GOOGLE_CLIENT_SECRET=placeholder
# OAUTH_GITHUB_CLIENT_ID=placeholder
# OAUTH_GITHUB_CLIENT_SECRET=placeholder
# OIDC_ISSUER_URL=placeholder
# OIDC_CLIENT_ID=placeholder
# OIDC_CLIENT_SECRET=placeholder
# OIDC_SCOPE=openid profile email
# OIDC_DEFAULT_WORKSPACE_ID=1
# IDME_CLIENT_ID=placeholder
# IDME_CLIENT_SECRET=placeholder
# IDME_REDIRECT_PATH=api/auth/idme/callback
